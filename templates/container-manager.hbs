{{!--
  Container Manager. Contents are real items on the actor (flagged containedIn),
  so nothing here changes what core weighs — it only changes where gear sits.
--}}
<div class="acks-equipment-containers__body">

  <header class="acks-equipment-containers__summary">
    <span>
      {{localize "ACKS-EQUIPMENT.container.encumbrance"}}
      <strong>{{encumbrance.value}} / {{encumbrance.max}} st</strong>
    </span>
    {{#if isOwner}}
      <button type="button" data-action="annotateGear" data-tooltip="{{localize 'ACKS-EQUIPMENT.container.annotateHint'}}">
        <i class="fas fa-wand-magic-sparkles"></i> {{localize "ACKS-EQUIPMENT.container.annotate"}}
      </button>
    {{/if}}
  </header>

  {{#if correction}}
    <p class="acks-equipment-containers__note"><em>{{correction}}</em></p>
  {{/if}}

  <div class="acks-equipment-container-scroll">

    {{#unless hasContainers}}
      <p class="acks-equipment-containers__empty">
        {{localize "ACKS-EQUIPMENT.container.noneYet"}}
      </p>
    {{/unless}}

    {{#each containers}}
      <section class="acks-equipment-container {{#if this.over}}over{{/if}}" data-drop-target="{{this.id}}">
        <header class="acks-equipment-container__header" data-item-id="{{this.id}}" draggable="true">
          <img src="{{this.img}}" alt="{{this.name}}" class="acks-equipment-container__icon" data-action="openItem" data-item-id="{{this.id}}">
          <span class="acks-equipment-container__name">{{this.name}}</span>
          <span class="acks-equipment-container__load">{{this.label}}</span>
          {{#if ../isOwner}}
            <span class="acks-equipment-container__controls">
              <a data-action="emptyContainer" data-item-id="{{this.id}}"
                 data-tooltip="{{localize 'ACKS-EQUIPMENT.container.empty'}}"><i class="fas fa-arrow-up-from-bracket"></i></a>
              <a data-action="unmakeContainer" data-item-id="{{this.id}}"
                 data-tooltip="{{localize 'ACKS-EQUIPMENT.container.unmake'}}"><i class="fas fa-box-open"></i></a>
            </span>
          {{/if}}
        </header>

        {{#if this.capacityStone}}
          <div class="acks-equipment-container__bar"><div class="acks-equipment-container__fill" style="width:{{this.pct}}%"></div></div>
        {{/if}}

        <ul class="acks-equipment-container__contents unlist">
          {{#each this.contents}}
            <li class="acks-equipment-container__row" data-item-id="{{this.id}}" draggable="true">
              <img src="{{this.img}}" alt="{{this.name}}" data-action="openItem" data-item-id="{{this.id}}">
              <span class="acks-equipment-container__row-name">{{this.name}}</span>
              <span class="acks-equipment-container__row-weight">{{this.weight}} st</span>
              {{#if ../../isOwner}}
                <a data-action="takeOut" data-item-id="{{this.id}}"
                   data-tooltip="{{localize 'ACKS-EQUIPMENT.container.takeOut'}}"><i class="fas fa-xmark"></i></a>
              {{/if}}
            </li>
          {{else}}
            <li class="acks-equipment-container__row empty"><em>{{localize "ACKS-EQUIPMENT.container.emptyHint"}}</em></li>
          {{/each}}
        </ul>
      </section>
    {{/each}}

    <section class="acks-equipment-container acks-equipment-container--loose" data-drop-target="loose">
      <header class="acks-equipment-container__header">
        <span class="acks-equipment-container__name">{{localize "ACKS-EQUIPMENT.container.carried"}}</span>
      </header>
      <ul class="acks-equipment-container__contents unlist">
        {{#each loose}}
          <li class="acks-equipment-container__row" data-item-id="{{this.id}}" draggable="true">
            <img src="{{this.img}}" alt="{{this.name}}" data-action="openItem" data-item-id="{{this.id}}">
            <span class="acks-equipment-container__row-name">
              {{this.name}}
              {{#if this.equipped}}<i class="fas fa-shield-halved acks-equipment-container__worn"
                 data-tooltip="{{localize 'ACKS-EQUIPMENT.container.wornHint'}}"></i>{{/if}}
            </span>
            <span class="acks-equipment-container__row-weight">{{this.weight}} st</span>
            {{#if ../isOwner}}
              <a data-action="makeContainer" data-item-id="{{this.id}}"
                 class="{{#if this.suggestible}}suggested{{/if}}"
                 data-tooltip="{{localize 'ACKS-EQUIPMENT.container.make'}}"><i class="fas fa-box"></i></a>
            {{/if}}
          </li>
        {{else}}
          <li class="acks-equipment-container__row empty"><em>{{localize "ACKS-EQUIPMENT.container.allStowed"}}</em></li>
        {{/each}}
      </ul>
    </section>

  </div>
</div>
